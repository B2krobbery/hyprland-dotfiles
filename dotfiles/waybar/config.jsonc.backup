{
  "layer": "top",
  "position": "top",
  "height": 32,

  "modules-left": ["hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock"],
  "modules-right": ["tray", "pulseaudio", "network", "bluetooth", "backlight", "battery"],

  "clock": {
    "format": "  {:%H:%M}",
    "tooltip-format": "{:%A, %d %B %Y}"
  },

  "network": {
    "format-wifi": "  {signalStrength}%",
    "format-ethernet": "󰈀 Wired",
    "format-disconnected": " No Net"
  },

  "pulseaudio": {
    "format": "  {volume}%",
    "format-muted": "󰝟 Muted",
    "on-click": "pavucontrol"
  },

  "bluetooth": {
    "format": "",
    "on-click": "blueman-manager"
  },

  "backlight": {
    "format": "󰃟 {percent}%"
  },

  "battery": {
    "format": "  {capacity}%",
    "format-charging": " {capacity}%"
  },

  "tray": {
    "spacing": 10
  }
}
